# ===========================================
# FraudIntel - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-3.0-flash

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/fraudintel?retryWrites=true&w=majority
MONGODB_DATABASE=fraudintel

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8080
APP_ENV=development
LOG_LEVEL=INFO

# --- Agent Configuration ---
AGENT_TIMEOUT_SECONDS=30
MAX_GRAPH_DEPTH=4
VECTOR_SEARCH_LIMIT=5
